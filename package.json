{
  "name": "thaiakha-cherry-2026",
  "version": "1.0.0",
  "private": true,
  "description": "ThaiAkha monorepo — front (www.thaiakha.com) + admin (admin.thaiakha.com)",
  "scripts": {
    "dev:front": "pnpm --filter front dev",
    "dev:admin": "pnpm --filter admin dev",
    "build:front": "pnpm --filter front build",
    "build:admin": "pnpm --filter admin build",
    "build": "pnpm --filter front build && pnpm --filter admin build"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  }
}
